enum UserRole {
  ADMIN
  MANAGER
  STAFF
  DRIVER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  email        String?  @unique
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver Driver?

  @@map("user")
}
